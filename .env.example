# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=password
DB_NAME=icegate_boe
DB_PORT=3306

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# Payment (Razorpay)
RAZORPAY_KEY_ID=your_key
RAZORPAY_KEY_SECRET=your_secret

# ICEGATE
ICEGATE_API_URL=https://api.icegate.gov.in
ICEGATE_API_KEY=your_key

# Subscriptions
SUBSCRIPTION_BASIC_PRICE=999
SUBSCRIPTION_PROFESSIONAL_PRICE=2999
SUBSCRIPTION_ENTERPRISE_PRICE=9999
